{
  "name": "mpesa-stk",
  "version": "0.2.0",
  "description": "Reliability-focused STK Push lifecycle manager: idempotency, deduplication, polling fallback, and reconciliation",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "mpesa-stk-relay": "dist/bin/serve.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./adapters/memory": {
      "import": {
        "types": "./dist/adapters/memory.d.mts",
        "default": "./dist/adapters/memory.mjs"
      },
      "require": {
        "types": "./dist/adapters/memory.d.ts",
        "default": "./dist/adapters/memory.js"
      }
    },
    "./adapters/postgres": {
      "import": {
        "types": "./dist/adapters/postgres.d.mts",
        "default": "./dist/adapters/postgres.mjs"
      },
      "require": {
        "types": "./dist/adapters/postgres.d.ts",
        "default": "./dist/adapters/postgres.js"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server/index.d.mts",
        "default": "./dist/server/index.mjs"
      },
      "require": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      }
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "hono": "^4.12.10",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ronnyabuto/mpesa-stk.git"
  },
  "keywords": [
    "mpesa",
    "daraja",
    "stk-push",
    "safaricom",
    "payments",
    "kenya",
    "typescript",
    "webhook",
    "webhook-relay",
    "callback"
  ]
}
